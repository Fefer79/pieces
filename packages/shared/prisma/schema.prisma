datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  MECHANIC
  OWNER
  SELLER
  RIDER
  ADMIN
  ENTERPRISE
  LIAISON
  DRIVER
}

model User {
  id            String   @id @default(uuid())
  supabaseId    String   @unique @map("supabase_id")
  phone         String?  @unique
  name          String?
  email         String?  @unique
  roles         Role[]
  activeContext  Role?    @map("active_context")
  consentedAt   DateTime? @map("consented_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  dataDeletionRequests DataDeletionRequest[]
  vendor               Vendor?
  vehicles             Vehicle[]
  enterpriseMemberships EnterpriseMember[]
  initiatedOrders      Order[]  @relation("OrderInitiator")
  riderDeliveries      Delivery[] @relation("DeliveryRider")
  sellerReviews        SellerReview[] @relation("SellerReviewer")
  deliveryReviews      DeliveryReview[] @relation("DeliveryReviewer")
  disputes             Dispute[] @relation("DisputeOpener")
  returnRequests       ReturnOrder[] @relation("ReturnOrderRequester")
  notificationPreference NotificationPreference?
  managedVendors       Vendor[]      @relation("VendorManagedByLiaison")
  liaisonCatalogItems  CatalogItem[] @relation("CatalogItemCreatedByLiaison")
  activityLogs         ActivityLog[]
  driverProfiles       Driver[]      @relation("UserDriverProfile")

  @@map("users")
  @@index([phone], name: "idx_users_phone")
  @@index([email], name: "idx_users_email")
}

model ActivityLog {
  id         String   @id @default(uuid())
  actorId    String   @map("actor_id")
  actorRole  Role     @map("actor_role")
  action     String
  targetType String   @map("target_type")
  targetId   String?  @map("target_id")
  payload    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
  @@index([actorId, createdAt(sort: Desc)], name: "idx_activity_logs_actor")
  @@index([action, createdAt(sort: Desc)], name: "idx_activity_logs_action")
  @@index([targetType, targetId], name: "idx_activity_logs_target")
  @@index([createdAt(sort: Desc)], name: "idx_activity_logs_created_at")
}

enum DeletionRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VendorStatus {
  PENDING_ACTIVATION
  ACTIVE
  PAUSED
}

enum VendorType {
  FORMAL
  INFORMAL
}

enum KycType {
  RCCM
  CNI
}

enum GuaranteeType {
  RETURN_48H
  WARRANTY_30D
}

enum CatalogItemStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PartCondition {
  NEW
  USED
  REFURBISHED
}

enum PartSource {
  OEM
  AFTERMARKET
  COMPATIBLE
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  VENDOR_CONFIRMED
  DISPATCHED
  IN_TRANSIT
  DELIVERED
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  ORANGE_MONEY
  MTN_MOMO
  WAVE
  COD
}

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
}

enum DeliveryStatus {
  PENDING_ASSIGNMENT
  ASSIGNED
  PICKUP_IN_PROGRESS
  IN_TRANSIT
  DELIVERED
  CONFIRMED
  RETURNED
}

enum DeliveryMode {
  EXPRESS
  STANDARD
}

enum JobType {
  IMAGE_PROCESS_VARIANTS
  CATALOG_AI_IDENTIFY
  MAINTENANCE_REMINDER_SCAN
  BUFFER_STOCK_REPLENISH_SCAN
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Vendor {
  id          String       @id @default(uuid())
  userId      String?      @unique @map("user_id")
  user        User?        @relation(fields: [userId], references: [id])
  managedByLiaisonId String? @map("managed_by_liaison_id")
  managedByLiaison   User?  @relation("VendorManagedByLiaison", fields: [managedByLiaisonId], references: [id])
  shopName    String       @map("shop_name")
  contactName String       @map("contact_name")
  phone       String
  vendorType  VendorType   @map("vendor_type")
  status      VendorStatus @default(PENDING_ACTIVATION)
  commune     String?
  address     String?
  lat         Float?
  lng         Float?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  deliveryZones String[]         @default([]) @map("delivery_zones")

  isExternal     Boolean @default(false) @map("is_external")
  externalSource String? @unique @map("external_source")

  ordersDelivered  Int       @default(0) @map("orders_delivered")
  disputesOpened   Int       @default(0) @map("disputes_opened")
  avgReviewRating  Float?    @map("avg_review_rating")
  aggregateRating  Float?    @map("aggregate_rating")
  scoreUpdatedAt   DateTime? @map("score_updated_at")

  kyc                 VendorKyc?
  guaranteeSignatures VendorGuaranteeSignature[]
  catalogItems        CatalogItem[]
  contracts           VendorContract[]

  @@map("vendors")
  @@index([phone], name: "idx_vendors_phone")
  @@index([managedByLiaisonId], name: "idx_vendors_managed_by_liaison")
}

model VendorGuaranteeSignature {
  id            String        @id @default(uuid())
  vendorId      String        @map("vendor_id")
  vendor        Vendor        @relation(fields: [vendorId], references: [id])
  guaranteeType GuaranteeType @map("guarantee_type")
  signedAt      DateTime      @default(now()) @map("signed_at")

  @@map("vendor_guarantee_signatures")
  @@unique([vendorId, guaranteeType], name: "uq_vendor_guarantee_type")
}

model VendorKyc {
  id             String   @id @default(uuid())
  vendorId       String   @unique @map("vendor_id")
  vendor         Vendor   @relation(fields: [vendorId], references: [id])
  kycType        KycType  @map("kyc_type")
  documentNumber String   @map("document_number")
  isPublic       Boolean  @default(false) @map("is_public")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("vendor_kyc")
}

enum VendorContractStatus {
  PENDING
  ACCEPTED
  REVOKED
}

// Contrat d'adhésion vendeur (CGU) envoyé par lien et signé électroniquement.
// Un enregistrement par lien généré ; statut PENDING jusqu'à signature.
model VendorContract {
  id              String               @id @default(uuid())
  token           String               @unique
  contractVersion String               @map("contract_version")
  status          VendorContractStatus @default(PENDING)

  // Vendeur existant (optionnel : un lien peut être envoyé à un prospect).
  vendorId String? @map("vendor_id")
  vendor   Vendor? @relation(fields: [vendorId], references: [id])

  // Informations pré-remplies par l'émetteur du lien (admin / liaison).
  sellerName String  @map("seller_name")
  shopName   String? @map("shop_name")
  phone      String?

  // Émetteur du lien (traçabilité).
  createdById String? @map("created_by_id")

  // Preuve d'acceptation.
  signedName        String?   @map("signed_name")
  signedAt          DateTime? @map("signed_at")
  acceptedIp        String?   @map("accepted_ip")
  acceptedUserAgent String?   @map("accepted_user_agent")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("vendor_contracts")
  @@index([vendorId], name: "idx_vendor_contracts_vendor")
  @@index([status], name: "idx_vendor_contracts_status")
}

model DataDeletionRequest {
  id          String                @id @default(uuid())
  userId      String                @map("user_id")
  user        User                  @relation(fields: [userId], references: [id])
  status      DeletionRequestStatus @default(PENDING)
  requestedAt DateTime              @default(now()) @map("requested_at")
  processedAt DateTime?             @map("processed_at")

  @@map("data_deletion_requests")
  @@index([userId], name: "idx_data_deletion_requests_user")
}

model CatalogItem {
  id                   String            @id @default(uuid())
  vendorId             String            @map("vendor_id")
  vendor               Vendor            @relation(fields: [vendorId], references: [id])
  createdByLiaisonId   String?           @map("created_by_liaison_id")
  createdByLiaison     User?             @relation("CatalogItemCreatedByLiaison", fields: [createdByLiaisonId], references: [id])
  name                 String?
  category             String?
  oemReference         String?           @map("oem_reference")
  vehicleCompatibility String?           @map("vehicle_compatibility")
  suggestedPrice       Int?              @map("suggested_price")
  price                Int?
  status               CatalogItemStatus @default(DRAFT)
  imageOriginalUrl     String?           @map("image_original_url")
  imageThumbUrl        String?           @map("image_thumb_url")
  imageSmallUrl        String?           @map("image_small_url")
  imageMediumUrl       String?           @map("image_medium_url")
  imageLargeUrl        String?           @map("image_large_url")
  serialPhotoUrl       String?           @map("serial_photo_url")
  aiConfidence         Float?            @map("ai_confidence")
  aiGenerated          Boolean           @default(true) @map("ai_generated")
  qualityScore         Float?            @map("quality_score")
  qualityIssue         String?           @map("quality_issue")
  inStock              Boolean           @default(true) @map("in_stock")
  condition            PartCondition?
  partSource           PartSource?       @map("part_source")
  warrantyMonths       Int?              @map("warranty_months")
  priceUpdatedAt       DateTime?         @map("price_updated_at")
  priceAlertFlag       Boolean           @default(false) @map("price_alert_flag")
  commissionAmount     Int?              @map("commission_amount")
  commissionAcceptedAt DateTime?         @map("commission_accepted_at")
  externalSource       String?           @map("external_source")
  externalSourceId     String?           @map("external_source_id")
  externalSourceUrl    String?           @map("external_source_url")
  photos               CatalogItemPhoto[]
  fitments             CatalogItemFitment[]
  bufferStockEntries   EnterpriseBufferStock[]
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  @@map("catalog_items")
  @@index([vendorId, status], name: "idx_catalog_items_vendor_status")
  @@index([createdByLiaisonId], name: "idx_catalog_items_created_by_liaison")
  @@index([oemReference, partSource, condition], name: "idx_catalog_items_oem_group")
  @@unique([externalSource, externalSourceId], name: "uq_catalog_items_external")
}

model CatalogItemFitment {
  id            String      @id @default(uuid())
  catalogItemId String      @map("catalog_item_id")
  catalogItem   CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  brand         String
  model         String?
  yearFrom      Int?        @map("year_from")
  yearTo        Int?        @map("year_to")
  engine        String?
  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("catalog_item_fitments")
  @@index([brand, model], name: "idx_fitments_brand_model")
  @@index([catalogItemId], name: "idx_fitments_item")
}

model CatalogItemPhoto {
  id              String      @id @default(uuid())
  catalogItemId   String      @map("catalog_item_id")
  catalogItem     CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  position        Int
  urlOriginal     String      @map("url_original")
  urlThumb        String?     @map("url_thumb")
  urlSmall        String?     @map("url_small")
  urlMedium       String?     @map("url_medium")
  urlLarge        String?     @map("url_large")
  createdAt       DateTime    @default(now()) @map("created_at")

  @@map("catalog_item_photos")
  @@unique([catalogItemId, position], name: "uq_catalog_photo_position")
  @@index([catalogItemId], name: "idx_catalog_photos_item")
}

model Job {
  id          String    @id @default(uuid())
  type        JobType
  status      JobStatus @default(PENDING)
  payload     Json
  attempts    Int       @default(0)
  maxAttempts Int       @default(3) @map("max_attempts")
  error       String?
  scheduledAt DateTime? @map("scheduled_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("jobs")
  @@index([status, type], name: "idx_jobs_status_type")
}

enum VehicleUsageType {
  TRANSPORT
  CHANTIER
  LIVRAISON
  DIRECTION
  AUTRE
}

enum EnterpriseMemberRole {
  OWNER
  MANAGER
  MECHANIC
  ACCOUNTANT
}

model Enterprise {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  commune   String?
  address   String?
  lat       Float?
  lng       Float?
  rccm      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members             EnterpriseMember[]
  vehicles            Vehicle[]
  orders              Order[]
  maintenanceCenters  MaintenanceCenter[]
  bufferStock         EnterpriseBufferStock[]
  subscriptions       EnterpriseSubscription[]
  invoices            Invoice[]
  monthlyInvoices     EnterpriseMonthlyInvoice[]
  drivers             Driver[]

  @@map("enterprises")
  @@index([slug], name: "idx_enterprises_slug")
}

enum SubscriptionTier {
  FREE
  PRO_FLOTTE
  PRO_FLOTTE_PLUS
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubscriptionEventKind {
  CREATED
  TRIAL_STARTED
  TRIAL_ENDED
  ACTIVATED
  SUSPENDED
  REACTIVATED
  CANCELLED
  TIER_CHANGED
  CYCLE_CHANGED
  ROI_GUARANTEE_INVOKED
  SLA_BREACH
}

model Invoice {
  id                   String   @id @default(uuid())
  orderId              String   @unique @map("order_id")
  order                Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  enterpriseId         String?  @map("enterprise_id")
  enterprise           Enterprise? @relation(fields: [enterpriseId], references: [id])
  invoiceNumber        String   @unique @map("invoice_number")
  issuedAt             DateTime @default(now()) @map("issued_at")
  // Amounts en FCFA
  subtotalHt           Int      @map("subtotal_ht")
  tvaRate              Int      @default(18) @map("tva_rate") // pourcentage
  tvaAmount            Int      @map("tva_amount")
  totalTtc             Int      @map("total_ttc")
  // FNE / DGI compliance — nullable jusqu'à intégration FNE-CI officielle
  fneValidationNumber  String?  @map("fne_validation_number")
  fneQrPayload         String?  @map("fne_qr_payload")
  fneSubmittedAt       DateTime? @map("fne_submitted_at")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("invoices")
  @@index([enterpriseId], name: "idx_invoices_enterprise")
  @@index([issuedAt], name: "idx_invoices_issued_at")
}

model EnterpriseMonthlyInvoice {
  id            String   @id @default(uuid())
  enterpriseId  String   @map("enterprise_id")
  enterprise    Enterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  year          Int
  month         Int      // 1-12
  invoiceCount  Int      @default(0) @map("invoice_count")
  totalHt       Int      @default(0) @map("total_ht")
  tvaAmount     Int      @default(0) @map("tva_amount")
  totalTtc      Int      @default(0) @map("total_ttc")
  generatedAt   DateTime @default(now()) @map("generated_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("enterprise_monthly_invoices")
  @@unique([enterpriseId, year, month], name: "uq_enterprise_monthly")
  @@index([enterpriseId], name: "idx_monthly_invoices_enterprise")
}

model EnterpriseSubscription {
  id                String             @id @default(uuid())
  enterpriseId      String             @map("enterprise_id")
  enterprise        Enterprise         @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  tier              SubscriptionTier
  status            SubscriptionStatus @default(TRIALING)
  billingCycle      BillingCycle       @default(MONTHLY) @map("billing_cycle")
  trialEndsAt       DateTime?          @map("trial_ends_at")
  startedAt         DateTime           @default(now()) @map("started_at")
  currentPeriodEnd  DateTime?          @map("current_period_end")
  cancelledAt       DateTime?          @map("cancelled_at")
  notes             String?
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  events EnterpriseSubscriptionEvent[]

  @@map("enterprise_subscriptions")
  @@index([enterpriseId], name: "idx_enterprise_subs_enterprise")
  @@index([status], name: "idx_enterprise_subs_status")
}

model EnterpriseSubscriptionEvent {
  id             String                 @id @default(uuid())
  subscriptionId String                 @map("subscription_id")
  subscription   EnterpriseSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  kind           SubscriptionEventKind
  payload        Json?
  actorUserId    String?                @map("actor_user_id")
  createdAt      DateTime               @default(now()) @map("created_at")

  @@map("enterprise_subscription_events")
  @@index([subscriptionId], name: "idx_subscription_events_sub")
  @@index([kind], name: "idx_subscription_events_kind")
}

model EnterpriseBufferStock {
  id              String      @id @default(uuid())
  enterpriseId    String      @map("enterprise_id")
  enterprise      Enterprise  @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  catalogItemId   String      @map("catalog_item_id")
  catalogItem     CatalogItem @relation(fields: [catalogItemId], references: [id])
  targetQty       Int         @map("target_qty")
  currentQty      Int         @default(0) @map("current_qty")
  autoReplenish   Boolean     @default(false) @map("auto_replenish")
  // Anti-spam du job de réappro : on ne régénère pas un bon tant que le dernier
  // est récent ou non résolu. lastReplenishOrderId pointe le dernier bon créé.
  lastReplenishedAt   DateTime? @map("last_replenished_at")
  lastReplenishOrderId String?  @map("last_replenish_order_id")
  notes           String?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  @@map("enterprise_buffer_stock")
  @@unique([enterpriseId, catalogItemId], name: "uq_enterprise_buffer_item")
  @@index([enterpriseId], name: "idx_buffer_stock_enterprise")
}

model MaintenanceCenter {
  id              String     @id @default(uuid())
  enterpriseId    String     @map("enterprise_id")
  enterprise      Enterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  name            String
  commune         String?
  address         String?
  lat             Float?
  lng             Float?
  contactName     String?    @map("contact_name")
  contactPhone    String?    @map("contact_phone")
  deliveryDayOfWeek Int?     @map("delivery_day_of_week")
  active          Boolean    @default(true)
  notes           String?
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  vehicles Vehicle[] @relation("VehicleHomeCenter")

  @@map("maintenance_centers")
  @@index([enterpriseId], name: "idx_maintenance_centers_enterprise")
}

model EnterpriseMember {
  id           String               @id @default(uuid())
  enterpriseId String               @map("enterprise_id")
  enterprise   Enterprise           @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  userId       String               @map("user_id")
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         EnterpriseMemberRole @default(MECHANIC)
  invitedAt    DateTime?            @map("invited_at")
  joinedAt     DateTime?            @map("joined_at")
  createdAt    DateTime             @default(now()) @map("created_at")

  @@map("enterprise_members")
  @@unique([enterpriseId, userId], name: "uq_enterprise_member")
  @@index([userId], name: "idx_enterprise_members_user")
}

enum MaintenanceKind {
  OIL_CHANGE
  OIL_FILTER
  AIR_FILTER
  FUEL_FILTER
  CABIN_FILTER
  BRAKE_PADS_FRONT
  BRAKE_PADS_REAR
  TIMING_BELT
  TIRES
  COOLANT
  TRANSMISSION_FLUID
  OTHER
}

model MaintenanceSchedule {
  id              String          @id @default(uuid())
  vehicleId       String          @map("vehicle_id")
  vehicle         Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  kind            MaintenanceKind
  label           String?
  intervalKm      Int             @map("interval_km")
  warningKm       Int             @default(500) @map("warning_km")
  lastDoneAtKm    Int?            @map("last_done_at_km")
  lastDoneAt      DateTime?       @map("last_done_at")
  enabled         Boolean         @default(true)
  notes           String?
  lastNotifiedAt     DateTime?    @map("last_notified_at")
  lastNotifiedStatus String?      @map("last_notified_status")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@map("maintenance_schedules")
  @@index([vehicleId], name: "idx_maintenance_schedules_vehicle")
  @@index([vehicleId, kind], name: "idx_maintenance_schedules_vehicle_kind")
}

model Vehicle {
  id               String             @id @default(uuid())
  userId           String?            @map("user_id")
  user             User?              @relation(fields: [userId], references: [id])
  enterpriseId     String?            @map("enterprise_id")
  enterprise       Enterprise?        @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  homeCenterId     String?            @map("home_center_id")
  homeCenter       MaintenanceCenter? @relation("VehicleHomeCenter", fields: [homeCenterId], references: [id], onDelete: SetNull)
  brand            String
  model            String
  year             Int
  vin              String?
  plate            String?
  engine           String?
  mileage          Int?
  mileageUpdatedAt DateTime?         @map("mileage_updated_at")
  usageType        VehicleUsageType? @map("usage_type")
  groupName        String?           @map("group_name")
  photoUrl         String?           @map("photo_url")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  orders               Order[]
  maintenanceSchedules MaintenanceSchedule[]
  driverAssignments    DriverAssignment[]
  driverDailyRecords   DriverDailyRecord[]
  driverIncidents      DriverIncident[]

  @@map("vehicles")
  @@index([userId], name: "idx_vehicles_user")
  @@index([enterpriseId], name: "idx_vehicles_enterprise")
  @@index([plate], name: "idx_vehicles_plate")
  @@index([homeCenterId], name: "idx_vehicles_home_center")
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_BUYER
  RESOLVED_SELLER
  CLOSED
}

enum ReturnReason {
  DEFECTIVE
  WRONG_PART
  NOT_AS_DESCRIBED
  NO_LONGER_NEEDED
  OTHER
}

enum ReturnStatus {
  REQUESTED
  ACCEPTED
  PICKED_UP
  INSPECTED
  REFUNDED
  REJECTED
  CANCELLED
}

model ReturnOrder {
  id              String       @id @default(uuid())
  orderId         String       @map("order_id")
  order           Order        @relation(fields: [orderId], references: [id])
  orderItemId     String?      @map("order_item_id")
  enterpriseId    String?      @map("enterprise_id")
  requestedById   String       @map("requested_by_id")
  requestedBy     User         @relation("ReturnOrderRequester", fields: [requestedById], references: [id])
  reason          ReturnReason
  description     String?
  pickupAddress   String?      @map("pickup_address")
  pickupContactName  String?   @map("pickup_contact_name")
  pickupContactPhone String?   @map("pickup_contact_phone")
  status          ReturnStatus @default(REQUESTED)
  refundAmount    Int?         @map("refund_amount")
  evidence        String[]     @default([])
  requestedAt     DateTime     @default(now()) @map("requested_at")
  acceptedAt      DateTime?    @map("accepted_at")
  pickedUpAt      DateTime?    @map("picked_up_at")
  inspectedAt     DateTime?    @map("inspected_at")
  refundedAt      DateTime?    @map("refunded_at")
  rejectedAt      DateTime?    @map("rejected_at")
  cancelledAt     DateTime?    @map("cancelled_at")
  resolutionNote  String?      @map("resolution_note")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@map("return_orders")
  @@index([orderId], name: "idx_return_orders_order")
  @@index([enterpriseId, status], name: "idx_return_orders_enterprise_status")
  @@index([status], name: "idx_return_orders_status")
}

model SellerReview {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  order     Order    @relation(fields: [orderId], references: [id])
  vendorId  String   @map("vendor_id")
  reviewerId String  @map("reviewer_id")
  reviewer  User     @relation("SellerReviewer", fields: [reviewerId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("seller_reviews")
  @@unique([orderId, reviewerId], name: "uq_seller_review_order_user")
  @@index([vendorId], name: "idx_seller_reviews_vendor")
}

model DeliveryReview {
  id         String   @id @default(uuid())
  deliveryId String   @map("delivery_id")
  delivery   Delivery @relation(fields: [deliveryId], references: [id])
  riderId    String   @map("rider_id")
  reviewerId String   @map("reviewer_id")
  reviewer   User     @relation("DeliveryReviewer", fields: [reviewerId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("delivery_reviews")
  @@unique([deliveryId, reviewerId], name: "uq_delivery_review_delivery_user")
  @@index([riderId], name: "idx_delivery_reviews_rider")
}

model Dispute {
  id          String        @id @default(uuid())
  orderId     String        @map("order_id")
  order       Order         @relation(fields: [orderId], references: [id])
  openedBy    String        @map("opened_by")
  opener      User          @relation("DisputeOpener", fields: [openedBy], references: [id])
  status      DisputeStatus @default(OPEN)
  reason      String
  evidence    String[]      @default([])
  resolution  String?
  resolvedAt  DateTime?     @map("resolved_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@map("disputes")
  @@index([orderId], name: "idx_disputes_order")
}

model SearchSynonym {
  id         String @id @default(uuid())
  typo       String @unique
  correction String

  @@map("search_synonyms")
}

model Order {
  id              String        @id @default(uuid())
  initiatorId     String        @map("initiator_id")
  initiator       User          @relation("OrderInitiator", fields: [initiatorId], references: [id])
  vehicleId       String?       @map("vehicle_id")
  vehicle         Vehicle?      @relation(fields: [vehicleId], references: [id])
  enterpriseId    String?       @map("enterprise_id")
  enterprise      Enterprise?   @relation(fields: [enterpriseId], references: [id])
  ownerPhone      String?       @map("owner_phone")
  status          OrderStatus   @default(DRAFT)
  paymentMethod   PaymentMethod? @map("payment_method")
  shareToken      String        @unique @map("share_token")
  totalAmount     Int           @default(0) @map("total_amount")
  deliveryFee     Int           @default(0) @map("delivery_fee")
  laborCost       Int?          @map("labor_cost")
  vendorConfirmedAt DateTime?   @map("vendor_confirmed_at")
  paidAt          DateTime?     @map("paid_at")
  cancelledAt     DateTime?     @map("cancelled_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  items           OrderItem[]
  events          OrderEvent[]
  escrow          EscrowTransaction?
  delivery        Delivery?
  sellerReviews   SellerReview[]
  disputes        Dispute[]
  returns         ReturnOrder[]
  invoice         Invoice?

  @@map("orders")
  @@index([initiatorId], name: "idx_orders_initiator")
  @@index([status], name: "idx_orders_status")
  @@index([vehicleId], name: "idx_orders_vehicle")
  @@index([enterpriseId], name: "idx_orders_enterprise")
}

model OrderItem {
  id              String   @id @default(uuid())
  orderId         String   @map("order_id")
  order           Order    @relation(fields: [orderId], references: [id])
  catalogItemId   String   @map("catalog_item_id")
  vendorId        String   @map("vendor_id")
  vendorShopName  String   @map("vendor_shop_name")
  name            String
  category        String?
  priceSnapshot   Int      @map("price_snapshot")
  quantity        Int      @default(1)
  imageThumbUrl   String?  @map("image_thumb_url")
  condition       PartCondition? // snapshot de la condition à la commande
  partSource      PartSource?    @map("part_source")
  commissionAmount Int?    @map("commission_amount")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("order_items")
  @@index([orderId], name: "idx_order_items_order")
}

model OrderEvent {
  id        String      @id @default(uuid())
  orderId   String      @map("order_id")
  order     Order       @relation(fields: [orderId], references: [id])
  fromStatus OrderStatus? @map("from_status")
  toStatus  OrderStatus @map("to_status")
  actor     String?
  note      String?
  createdAt DateTime    @default(now()) @map("created_at")

  @@map("order_events")
  @@index([orderId], name: "idx_order_events_order")
}

model Delivery {
  id              String         @id @default(uuid())
  orderId         String         @unique @map("order_id")
  order           Order          @relation(fields: [orderId], references: [id])
  riderId         String?        @map("rider_id")
  rider           User?          @relation("DeliveryRider", fields: [riderId], references: [id])
  status          DeliveryStatus @default(PENDING_ASSIGNMENT)
  mode            DeliveryMode   @default(STANDARD)
  pickupAddress   String?        @map("pickup_address")
  pickupLat       Float?         @map("pickup_lat")
  pickupLng       Float?         @map("pickup_lng")
  deliveryAddress String?        @map("delivery_address")
  deliveryLat     Float?         @map("delivery_lat")
  deliveryLng     Float?         @map("delivery_lng")
  riderLat        Float?         @map("rider_lat")
  riderLng        Float?         @map("rider_lng")
  estimatedAt     DateTime?      @map("estimated_at")
  pickedUpAt      DateTime?      @map("picked_up_at")
  deliveredAt     DateTime?      @map("delivered_at")
  confirmedAt     DateTime?      @map("confirmed_at")
  clientAbsent    Boolean        @default(false) @map("client_absent")
  codAmount       Int?           @map("cod_amount")
  receiptPhotoUrl String?        @map("receipt_photo_url")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  deliveryReviews DeliveryReview[]

  @@map("deliveries")
  @@index([riderId], name: "idx_deliveries_rider")
  @@index([status], name: "idx_deliveries_status")
}

model EscrowTransaction {
  id        String       @id @default(uuid())
  orderId   String       @unique @map("order_id")
  order     Order        @relation(fields: [orderId], references: [id])
  amount    Int
  status    EscrowStatus @default(HELD)
  heldAt    DateTime     @default(now()) @map("held_at")
  releasedAt DateTime?   @map("released_at")
  refundedAt DateTime?   @map("refunded_at")

  @@map("escrow_transactions")
}

model NotificationPreference {
  id        String  @id @default(uuid())
  userId    String  @unique @map("user_id")
  user      User    @relation(fields: [userId], references: [id])
  whatsapp  Boolean @default(true)
  sms       Boolean @default(false)
  push      Boolean @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("notification_preferences")
}

// ============================================================================
// INGEST — canonical vehicle reference (Chantier 1)
// ============================================================================

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  ELECTRIC
  LPG
  CNG
  OTHER
}

enum BodyType {
  SEDAN
  HATCHBACK
  SUV
  PICKUP
  VAN
  TRUCK
  COUPE
  WAGON
  CONVERTIBLE
  MOTORCYCLE
  OTHER
}

model VehicleMake {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  country      String?
  popularityCi Int      @default(0) @map("popularity_ci")
  externalSource   String? @map("external_source")
  externalSourceId String? @map("external_source_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  models VehicleModel[]

  @@map("vehicle_makes")
  @@index([slug], name: "idx_vehicle_makes_slug")
  @@unique([externalSource, externalSourceId], name: "uq_vehicle_makes_external")
}

model VehicleModel {
  id        String   @id @default(uuid())
  makeId    String   @map("make_id")
  make      VehicleMake @relation(fields: [makeId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  yearStart Int?     @map("year_start")
  yearEnd   Int?     @map("year_end")
  bodyType  BodyType? @map("body_type")
  externalSource   String? @map("external_source")
  externalSourceId String? @map("external_source_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  generations VehicleGeneration[]

  @@map("vehicle_models")
  @@unique([makeId, slug], name: "uq_vehicle_model_make_slug")
  @@unique([externalSource, externalSourceId], name: "uq_vehicle_models_external")
  @@index([makeId], name: "idx_vehicle_models_make")
}

model VehicleGeneration {
  id        String   @id @default(uuid())
  modelId   String   @map("model_id")
  model     VehicleModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  code      String?
  yearStart Int      @map("year_start")
  yearEnd   Int?     @map("year_end")
  bodyType  BodyType? @map("body_type")
  externalSource   String? @map("external_source")
  externalSourceId String? @map("external_source_id")
  createdAt DateTime @default(now()) @map("created_at")

  engines VehicleEngine[]

  @@map("vehicle_generations")
  @@unique([externalSource, externalSourceId], name: "uq_vehicle_generations_external")
  @@index([modelId, yearStart], name: "idx_vehicle_generations_model_year")
}

model VehicleEngine {
  id            String   @id @default(uuid())
  generationId  String   @map("generation_id")
  generation    VehicleGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)
  code          String?
  displacementCc Int?    @map("displacement_cc")
  fuelType      FuelType? @map("fuel_type")
  powerKw       Int?     @map("power_kw")
  oemRefs       String[] @default([]) @map("oem_refs")
  externalSource   String? @map("external_source")
  externalSourceId String? @map("external_source_id")
  createdAt     DateTime @default(now()) @map("created_at")

  partFitments PartReferenceFitment[]

  @@map("vehicle_engines")
  @@unique([externalSource, externalSourceId], name: "uq_vehicle_engines_external")
  @@index([generationId], name: "idx_vehicle_engines_generation")
  @@index([code], name: "idx_vehicle_engines_code")
}

// ============================================================================
// INGEST — parts reference + market price (Chantier 2)
// ============================================================================

model PartCategory {
  id        String   @id @default(uuid())
  parentId  String?  @map("parent_id")
  parent    PartCategory? @relation("PartCategoryTree", fields: [parentId], references: [id])
  children  PartCategory[] @relation("PartCategoryTree")
  name      String
  slug      String   @unique
  oemGroup  String?  @map("oem_group")
  createdAt DateTime @default(now()) @map("created_at")

  references PartReference[]

  @@map("part_categories")
  @@index([parentId], name: "idx_part_categories_parent")
}

model PartReference {
  id         String   @id @default(uuid())
  oemNumber  String?  @map("oem_number")
  categoryId String?  @map("category_id")
  category   PartCategory? @relation(fields: [categoryId], references: [id])
  name       String
  brand      String?
  externalSource   String? @map("external_source")
  externalSourceId String? @map("external_source_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  fitments     PartReferenceFitment[]
  observations MarketPriceObservation[]

  @@map("part_references")
  @@unique([oemNumber, brand], name: "uq_part_ref_oem_brand")
  @@unique([externalSource, externalSourceId], name: "uq_part_references_external")
  @@index([categoryId], name: "idx_part_references_category")
  @@index([oemNumber], name: "idx_part_references_oem")
}

model PartReferenceFitment {
  id              String   @id @default(uuid())
  partReferenceId String   @map("part_reference_id")
  partReference   PartReference @relation(fields: [partReferenceId], references: [id], onDelete: Cascade)
  vehicleEngineId String   @map("vehicle_engine_id")
  vehicleEngine   VehicleEngine @relation(fields: [vehicleEngineId], references: [id], onDelete: Cascade)

  @@map("part_reference_fitments")
  @@unique([partReferenceId, vehicleEngineId], name: "uq_part_ref_fitment")
  @@index([vehicleEngineId], name: "idx_part_ref_fitments_engine")
}

enum IngestSource {
  HAUTOPARTS_3H
  MAPA_CI
  JUMIA_CI
  COINAFRIQUE_CI
  ANNUAIRE_CI
  GLOBAL_AUTO_CI
  OSM
  GOOGLE_PLACES
  NHTSA
  WIKIPEDIA
  PARTSOUQ
  MANUAL
}

model MarketPriceObservation {
  id              String   @id @default(uuid())
  partReferenceId String?  @map("part_reference_id")
  partReference   PartReference? @relation(fields: [partReferenceId], references: [id])
  rawTitle        String   @map("raw_title")
  source          IngestSource
  sourceUrl       String?  @map("source_url")
  sourceItemId    String?  @map("source_item_id")
  vendorName      String?  @map("vendor_name")
  priceFcfa       Int?     @map("price_fcfa")
  currency        String   @default("XOF")
  condition       PartCondition?
  partSource      PartSource? @map("part_source")
  observedAt      DateTime @default(now()) @map("observed_at")

  @@map("market_price_observations")
  @@unique([source, sourceItemId], name: "uq_market_price_source_item")
  @@index([partReferenceId], name: "idx_market_price_part_ref")
  @@index([source, observedAt], name: "idx_market_price_source_time")
}

// ============================================================================
// INGEST — competitor cartography (Chantier 3 / Phase 4)
// ============================================================================

enum CompetitorType {
  ONLINE
  OFFLINE
  HYBRID
}

enum CompetitorSize {
  SMALL
  MEDIUM
  LARGE
}

model CompetitorVendor {
  id             String   @id @default(uuid())
  name           String
  type           CompetitorType
  websiteUrl     String?  @map("website_url")
  phone          String?
  whatsapp       String?
  email          String?
  address        String?
  zone           String?
  commune        String?
  lat            Float?
  lng            Float?
  osmId          String?  @unique @map("osm_id")
  gmapsPlaceId   String?  @unique @map("gmaps_place_id")
  specialties    String[] @default([])
  estimatedSize  CompetitorSize? @map("estimated_size")
  rating         Float?
  reviewsCount   Int?     @map("reviews_count")
  notes          String?
  observedAt     DateTime @default(now()) @map("observed_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("competitor_vendors")
  @@index([type, zone], name: "idx_competitor_vendors_type_zone")
  @@index([commune], name: "idx_competitor_vendors_commune")
}

// ===========================================================================
// Gestion des chauffeurs (flotte) — onboarding + comptes, CA journalier,
// affectation véhicule, incidents/impact. Rattaché à une Enterprise.
// ===========================================================================

enum DriverStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

model Driver {
  id              String       @id @default(uuid())
  enterpriseId    String       @map("enterprise_id")
  enterprise      Enterprise   @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  // Lié au compte utilisateur du chauffeur une fois qu'il s'est connecté (OTP
  // sur le même téléphone). Null tant qu'il n'a pas activé son accès.
  userId          String?      @map("user_id")
  user            User?        @relation("UserDriverProfile", fields: [userId], references: [id], onDelete: SetNull)
  name            String
  phone           String       // format +225XXXXXXXXXX
  licenseNumber   String?      @map("license_number")
  licenseCategory String?      @map("license_category")
  photoUrl        String?      @map("photo_url")
  status          DriverStatus @default(ACTIVE)
  hiredAt         DateTime?    @map("hired_at")
  notes           String?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  assignments  DriverAssignment[]
  dailyRecords DriverDailyRecord[]
  incidents    DriverIncident[]

  @@map("drivers")
  @@unique([enterpriseId, phone], name: "uq_driver_phone")
  @@index([enterpriseId], name: "idx_drivers_enterprise")
  @@index([userId], name: "idx_drivers_user")
}

// Historique d'affectation chauffeur ↔ véhicule (endedAt = null → affectation active).
model DriverAssignment {
  id        String    @id @default(uuid())
  driverId  String    @map("driver_id")
  driver    Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicleId String    @map("vehicle_id")
  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("driver_assignments")
  @@index([driverId], name: "idx_driver_assignments_driver")
  @@index([vehicleId], name: "idx_driver_assignments_vehicle")
}

// Relevé quotidien saisi par le chauffeur : CA, carburant, dépenses, km.
model DriverDailyRecord {
  id            String   @id @default(uuid())
  driverId      String   @map("driver_id")
  driver        Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicleId     String?  @map("vehicle_id")
  vehicle       Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  date          DateTime @db.Date
  revenue       Int      @default(0) // CA du jour (FCFA)
  fuelCost      Int      @default(0) @map("fuel_cost")
  otherExpenses Int      @default(0) @map("other_expenses")
  kmDriven      Int?     @map("km_driven")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("driver_daily_records")
  @@unique([driverId, date], name: "uq_driver_day")
  @@index([driverId], name: "idx_driver_daily_driver")
  @@index([vehicleId], name: "idx_driver_daily_vehicle")
}

enum DriverIncidentType {
  ACCIDENT
  INFRACTION
  BREAKDOWN
  COMPLAINT
  OTHER
}

enum DriverIncidentSeverity {
  LOW
  MEDIUM
  HIGH
}

// Journal d'incidents/conduite — impact véhicule et rentabilité.
model DriverIncident {
  id           String                 @id @default(uuid())
  driverId     String                 @map("driver_id")
  driver       Driver                 @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicleId    String?                @map("vehicle_id")
  vehicle      Vehicle?               @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  type         DriverIncidentType
  severity     DriverIncidentSeverity @default(LOW)
  date         DateTime               @db.Date
  description  String?
  costEstimate Int?                   @map("cost_estimate")
  createdAt    DateTime               @default(now()) @map("created_at")

  @@map("driver_incidents")
  @@index([driverId], name: "idx_driver_incidents_driver")
  @@index([vehicleId], name: "idx_driver_incidents_vehicle")
}
