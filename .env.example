# ===========================================
# Pièces — Environment Variables Template
# ===========================================
# Copy this file to .env.local and fill in values

# --- Next.js Web ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Fastify API ---
DATABASE_URL=postgresql://user:password@localhost:5432/pieces
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SENTRY_DSN=
PINO_LOG_LEVEL=info
PORT=3001

# --- Cloudflare R2 (REQUIRED for image uploads) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=pieces-images
R2_PUBLIC_URL=https://images.pieces.ci

# --- Google Gemini (REQUIRED for AI part identification) ---
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_QUOTA_ALERT_THRESHOLD=0.8

# --- External Services (added in future stories) ---
